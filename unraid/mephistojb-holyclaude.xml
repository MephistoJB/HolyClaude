<?xml version="1.0"?>
<Container version="2">
  <Name>holyclaude</Name>
  <Repository>ghcr.io/mephistojb/holyclaude:edge</Repository>
  <Registry>https://ghcr.io</Registry>
  <Network>bridge</Network>
  <MyIP></MyIP>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support>https://github.com/MephistoJB/HolyClaude</Support>
  <Project>https://github.com/MephistoJB/HolyClaude</Project>
  <Overview>HolyClaude with Codex LM Studio support, packaged for Unraid without docker-compose.</Overview>
  <Category>Productivity:</Category>
  <WebUI>http://[IP]:[PORT:3001]</WebUI>
  <Icon>https://raw.githubusercontent.com/MephistoJB/HolyClaude/master/assets/logo.png</Icon>
  <ExtraParams>--restart=unless-stopped --shm-size=2g --cap-add=SYS_ADMIN --cap-add=SYS_PTRACE --security-opt seccomp=unconfined</ExtraParams>
  <PostArgs></PostArgs>
  <CPUset></CPUset>
  <DateInstalled></DateInstalled>
  <DonateText></DonateText>
  <DonateLink></DonateLink>
  <Requires></Requires>
  <Config Name="Web UI Port" Target="3001" Default="3001" Mode="tcp" Description="HolyClaude Web UI" Type="Port" Display="always" Required="true" Mask="false">3001</Config>
  <Config Name="HolyClaude Data" Target="/home/claude/.claude" Default="/mnt/user/appdata/holyclaude/data" Mode="rw" Description="Persistent HolyClaude settings, login state, memories and app data" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/holyclaude/data</Config>
  <Config Name="Codex Config" Target="/home/claude/.claude/.codex" Default="/mnt/user/appdata/holyclaude/codex" Mode="rw" Description="Optional dedicated nested mount for Codex config and session data" Type="Path" Display="advanced" Required="false" Mask="false">/mnt/user/appdata/holyclaude/codex</Config>
  <Config Name="Workspace" Target="/workspace" Default="/mnt/user/dev/repositories" Mode="rw" Description="Projects visible to HolyClaude and Codex" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/dev/repositories</Config>
  <Config Name="Timezone" Target="TZ" Default="Europe/Berlin" Mode="" Description="Container timezone" Type="Variable" Display="always" Required="true" Mask="false">Europe/Berlin</Config>
  <Config Name="PUID" Target="PUID" Default="99" Mode="" Description="Unraid user id" Type="Variable" Display="advanced" Required="false" Mask="false">99</Config>
  <Config Name="PGID" Target="PGID" Default="100" Mode="" Description="Unraid group id" Type="Variable" Display="advanced" Required="false" Mask="false">100</Config>
  <Config Name="Node Memory" Target="NODE_OPTIONS" Default="--max-old-space-size=4096" Mode="" Description="Node.js memory limit" Type="Variable" Display="advanced" Required="false" Mask="false">--max-old-space-size=4096</Config>
  <Config Name="OpenAI API Key" Target="OPENAI_API_KEY" Default="" Mode="" Description="Optional OpenAI API key for Codex API auth. Leave empty for LM Studio." Type="Variable" Display="advanced" Required="false" Mask="true"></Config>
  <Config Name="Codex LM Studio URL" Target="HOLYCLAUDE_CODEX_BASE_URL" Default="http://macserver:1234/v1" Mode="" Description="LM Studio or other OpenAI-compatible endpoint for Codex" Type="Variable" Display="always" Required="false" Mask="false">http://macserver:1234/v1</Config>
  <Config Name="Codex Model" Target="HOLYCLAUDE_CODEX_MODEL" Default="qwen3.6-27b-mlx" Mode="" Description="Model id from LM Studio /v1/models" Type="Variable" Display="always" Required="false" Mask="false">qwen3.6-27b-mlx</Config>
  <Config Name="Codex Chat Permission" Target="HOLYCLAUDE_CODEX_CHAT_PERMISSION_MODE" Default="acceptEdits" Mode="" Description="CloudCLI Codex browser mode: default, acceptEdits, bypassPermissions" Type="Variable" Display="advanced" Required="false" Mask="false">acceptEdits</Config>
  <Config Name="Codex CLI Permission" Target="HOLYCLAUDE_CODEX_CLI_PERMISSION_MODE" Default="acceptEdits" Mode="" Description="Raw codex CLI first-boot mode: default, acceptEdits, bypassPermissions" Type="Variable" Display="advanced" Required="false" Mask="false">acceptEdits</Config>
</Container>
